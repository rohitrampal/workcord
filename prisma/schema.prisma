// Prisma schema for PraXio - Enterprise Workforce Management System
// Database: PostgreSQL
// ORM: Prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Discord Server (Guild) Information
model Guild {
  id                String   @id // Discord Guild ID
  name              String
  ownerId           String
  botInstalledAt    DateTime @default(now())
  isProvisioned     Boolean  @default(false)
  timezone          String   @default("Asia/Kolkata")
  reminderTimes     Json?    // { todoReminder: "09:15", eodReminder: "18:00", defaulterCheck: { todo: "10:00", eod: "19:00" } }
  penaltyConfig     Json?    // { todoDefault: 1, eodDefault: 1, attendanceDefault: 2 }
  leaveQuotas       Json?    // { sick: 12, casual: 12, earned: 15, unpaid: 0 }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  roles             Role[]
  channels          Channel[]
  users             User[]
  todos             Todo[]
  updates           Update[]
  tasks             Task[]
  plannerPlans      PlannerPlan[]
  attendance        Attendance[]
  leaves            Leave[]
  auditLogs         AuditLog[]
  conciergeChannels ConciergeChannel[]

  @@index([isProvisioned])
  @@map("guilds")
}

// Role Definitions and Permissions
model Role {
  id          String   @id // Discord Role ID
  guildId     String
  name        String
  level       Int      // 1=Super Admin, 2=Admin, 3=Business Owner, 4=Stakeholder, 5=Leader, 6=Manager, 7=Individual Contributor
  permissions Json?    // Discord permission flags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([guildId, name])
  @@index([guildId, level])
  @@map("roles")
}

// Channel Configurations
model Channel {
  id          String   @id // Discord Channel ID
  guildId     String
  name        String
  type        String   // "general", "admin", "leadership", "marketing", "sales", "accounts", "operations", "tech", "support", "concierge"
  isWfmEnabled Boolean  @default(false) // For To-Do and EOD reminders
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  todos       Todo[]
  updates     Update[]
  tasks       Task[]

  @@unique([guildId, name])
  @@index([guildId, type])
  @@index([guildId, isWfmEnabled])
  @@map("channels")
}

// User Profiles and Role Mappings
model User {
  id            String   @id // Discord User ID
  guildId       String
  username      String
  discriminator String?
  email         String?
  phone         String?
  roleId        String?
  joinedAt      DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  role          Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  todos         Todo[]
  updates       Update[]
  tasksAssigned Task[]   @relation("TaskAssignee")
  tasksCreated  Task[]   @relation("TaskCreator")
  attendance    Attendance[]
  leaves        Leave[]
  auditLogs     AuditLog[]
  conciergeChannel ConciergeChannel?

  @@unique([guildId, id])
  @@index([guildId, roleId])
  @@index([guildId, isActive])
  @@map("users")
}

// To-Do List Entries
model Todo {
  id          String   @id @default(uuid())
  guildId     String
  userId      String
  channelId   String
  content     String   @db.Text
  date        DateTime @db.Date
  postedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, channelId, date])
  @@index([guildId, channelId, date])
  @@index([userId, date])
  @@map("todos")
}

// EOD Update Entries
model Update {
  id          String   @id @default(uuid())
  guildId     String
  userId      String
  channelId   String
  completed   String?  @db.Text
  inProgress  String?  @db.Text
  blockers    String?  @db.Text
  date        DateTime @db.Date
  postedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, channelId, date])
  @@index([guildId, channelId, date])
  @@index([userId, date])
  @@map("updates")
}

// Task Assignments and Tracking
model Task {
  id          String   @id @default(uuid())
  guildId     String
  title       String
  description String?  @db.Text
  assigneeId  String
  creatorId   String
  channelId   String?
  status      String   @default("Not Started") // Not Started, In Progress, Blocked, Completed, Cancelled
  priority    String   @default("Normal") // Low, Normal, High, Critical
  dueDate     DateTime?
  blockerReason String? @db.Text
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  assignee    User     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([guildId, assigneeId, status])
  @@index([guildId, status])
  @@index([dueDate])
  @@map("tasks")
}

// Sprint and OKR Data
model PlannerPlan {
  id          String   @id @default(uuid())
  guildId     String
  type        String   // "sprint", "okr", "goal"
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  status      String   @default("Active") // Active, Completed, Cancelled
  metadata    Json?    // Flexible data: goals, key results, tasks, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, type, status])
  @@index([guildId, startDate, endDate])
  @@map("planner_plans")
}

// Check-in/Check-out Records
model Attendance {
  id          String   @id @default(uuid())
  guildId     String
  userId      String
  checkInAt   DateTime
  checkOutAt  DateTime?
  location    String   // Office, WFH, Outdoor, Site Visit
  hoursWorked Float?
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId, date])
  @@index([guildId, userId, date])
  @@index([guildId, date])
  @@map("attendance")
}

// Leave Applications and Approvals
model Leave {
  id            String   @id @default(uuid())
  guildId       String
  userId        String
  leaveType     String   // Sick Leave, Casual Leave, Earned Leave, Unpaid Leave
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  reason        String   @db.Text
  status        String   @default("Pending") // Pending, Approved, Rejected
  approvedBy    String?
  approvedAt    DateTime?
  rejectionReason String? @db.Text
  applicationId String   @default(uuid()) // User-facing ID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([applicationId])
  @@index([guildId, userId, status])
  @@index([guildId, status])
  @@index([startDate, endDate])
  @@map("leaves")
}

// Complete Action Audit Trail
model AuditLog {
  id          String   @id @default(uuid())
  guildId     String
  userId      String
  action      String   // Role change, channel modification, command usage, leave approval, etc.
  entityType  String?  // "role", "channel", "leave", "task", etc.
  entityId    String?
  details     Json?    // Flexible data for action-specific information
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId, userId, createdAt])
  @@index([guildId, action, createdAt])
  @@index([guildId, entityType, entityId])
  @@map("audit_logs")
}

// User-to-Channel Mappings for Concierge
model ConciergeChannel {
  id          String   @id @default(uuid())
  guildId     String
  userId      String   @unique
  channelId   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@index([channelId])
  @@map("concierge_channels")
}
